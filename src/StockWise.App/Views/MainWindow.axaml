<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StockWise.App.ViewModels"
        xmlns:views="clr-namespace:StockWise.App.Views"
        xmlns:models="clr-namespace:StockWise.App.Models"
        xmlns:converters="clr-namespace:StockWise.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="StockWise.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="StockWise — Управление складом"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}">

    <Window.Resources>
        <converters:ToastTypeToBrushConverter x:Key="ToastTypeToBrushConverter" />
    </Window.Resources>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:ItemListViewModel">
            <views:ItemListView />
        </DataTemplate>
        <DataTemplate DataType="vm:ItemEditViewModel">
            <views:ItemEditView />
        </DataTemplate>
        <DataTemplate DataType="vm:CategoryListViewModel">
            <views:CategoryListView />
        </DataTemplate>
        <DataTemplate DataType="vm:WarehouseListViewModel">
            <views:WarehouseListView />
        </DataTemplate>
        <DataTemplate DataType="vm:WarehouseEditViewModel">
            <views:WarehouseEditView />
        </DataTemplate>
        <DataTemplate DataType="vm:StockViewModel">
            <views:StockView />
        </DataTemplate>
        <DataTemplate DataType="vm:DocumentListViewModel">
            <views:DocumentListView />
        </DataTemplate>
        <DataTemplate DataType="vm:DocumentEditViewModel">
            <views:DocumentEditView />
        </DataTemplate>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:ReportsViewModel">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="vm:OrderListViewModel">
            <views:OrderListView />
        </DataTemplate>
        <DataTemplate DataType="vm:OrderEditViewModel">
            <views:OrderEditView />
        </DataTemplate>
        <DataTemplate DataType="vm:InventoryListViewModel">
            <views:InventoryListView />
        </DataTemplate>
        <DataTemplate DataType="vm:InventoryEditViewModel">
            <views:InventoryEditView />
        </DataTemplate>
        <DataTemplate DataType="vm:UserListViewModel">
            <views:UserListView />
        </DataTemplate>
        <DataTemplate DataType="vm:UserEditViewModel">
            <views:UserEditView />
        </DataTemplate>
        <DataTemplate DataType="vm:CustomerListViewModel">
            <views:CustomerListView />
        </DataTemplate>
        <DataTemplate DataType="vm:CustomerEditViewModel">
            <views:CustomerEditView />
        </DataTemplate>
    </Window.DataTemplates>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="240,*">

        <Border Grid.Column="0" Background="{DynamicResource SidebarBg}">
            <Grid RowDefinitions="Auto,*,Auto">

                <Border Grid.Row="0" Classes="logoArea">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="📦" FontSize="24" VerticalAlignment="Center" />
                        <TextBlock Text="StockWise" Classes="logoText" />
                        <TextBlock Text="{Binding Version}" Classes="logoVersion" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <StackPanel>

                        <TextBlock Text="НАВИГАЦИЯ" Classes="sidebarSection" />
                        <RadioButton Content="📊  Дашборд" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Dashboard}"
                                     IsChecked="True" />
                        <RadioButton Content="📦  Товары" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Items}"
                                     IsVisible="{Binding CanViewItems}" />
                        <RadioButton Content="📂  Категории" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Categories}"
                                     IsVisible="{Binding CanViewCategories}" />
                        <RadioButton Content="🏭  Склады" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Warehouses}"
                                     IsVisible="{Binding CanViewWarehouses}" />
                        <RadioButton Content="📦  Остатки" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Stock}"
                                     IsVisible="{Binding CanViewStock}" />
                        <RadioButton Content="📄  Документы" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Documents}"
                                     IsVisible="{Binding CanViewDocuments}" />
                        <RadioButton Content="📋  Заказы" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Orders}"
                                     IsVisible="{Binding CanViewOrders}" />
                        <RadioButton Content="🔄  Инвентаризация" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Inventory}"
                                     IsVisible="{Binding CanViewInventory}" />

                        <Border Classes="sidebarDivider" />

                        <TextBlock Text="АНАЛИТИКА" Classes="sidebarSection" />
                        <RadioButton Content="📈  Отчёты" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Reports}"
                                     IsVisible="{Binding CanViewReports}" />

                        <Border Classes="sidebarDivider"
                                IsVisible="{Binding CanViewUsers}" />

                        <TextBlock Text="АДМИНИСТРИРОВАНИЕ" Classes="sidebarSection"
                                   IsVisible="{Binding CanViewUsers}" />
                        <RadioButton Content="👥  Пользователи" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Users}"
                                     IsVisible="{Binding CanViewUsers}" />
                        <RadioButton Content="👤  Контрагенты" Classes="navItem"
                                     GroupName="nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="{x:Static vm:PageType.Customers}"
                                     IsVisible="{Binding CanViewCustomers}" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Classes="userArea">
                    <Grid ColumnDefinitions="36,*,Auto,Auto">
                        <Border Grid.Column="0" Classes="avatar">
                            <TextBlock Text="U" FontSize="16" FontWeight="700"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding UserDisplayName}" FontSize="14" FontWeight="600"
                                       Foreground="{DynamicResource SidebarTextSelected}" />
                            <TextBlock Text="{Binding UserEmail}" FontSize="11"
                                       Foreground="{DynamicResource SidebarText}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="{Binding ThemeIcon}"
                                Classes="userLogout"
                                Command="{Binding ToggleThemeCommand}"
                                ToolTip.Tip="Сменить тему" />
                        <Button Grid.Column="3" Content="⏻"
                                Classes="userLogout"
                                Command="{Binding LogoutCommand}"
                                ToolTip.Tip="Выйти" />
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">

            <Border Grid.Row="0" Classes="pageHeader">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding ActivePageName}" Classes="pageTitle" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding CurrentDate}"
                               Classes="pageDate" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pageHeaderAccent" />

            <Border Grid.Row="2" IsHitTestVisible="False"
                    Background="{StaticResource GridPattern}"
                    Opacity="0.12"
                    Classes="animatedGrid" />
            <ContentControl Grid.Row="2" Content="{Binding CurrentPageViewModel}"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Stretch">
                <ContentControl.Styles>
                    <Style Selector="ContentControl > UserControl">
                        <Style.Animations>
                            <Animation Duration="0:0:0.3" FillMode="Both">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="12" />
                                        </Setter.Value>
                                    </Setter>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="0" />
                                        </Setter.Value>
                                    </Setter>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </ContentControl.Styles>
                <ContentControl.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
                    </Transitions>
                </ContentControl.Transitions>
            </ContentControl>

            <!-- Ambient overlays (on top of content, non-interactive) -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    IsHitTestVisible="False"
                    Background="{StaticResource ScanlineBrush}"
                    Classes="scanlineOverlay" />
            <Border Grid.Row="0" Grid.RowSpan="3"
                    IsHitTestVisible="False"
                    Background="{StaticResource VignetteGradient}" />

            <!-- Floating particles -->
            <Grid Grid.Row="0" Grid.RowSpan="3"
                  IsHitTestVisible="False">
                <Ellipse Fill="{DynamicResource AccentCyan}"
                         Width="3" Height="3" Opacity="0.2"
                         Classes="particle p1" />
                <Ellipse Fill="{DynamicResource AccentMagenta}"
                         Width="2" Height="2" Opacity="0.15"
                         Classes="particle p2" />
                <Ellipse Fill="{DynamicResource AccentCyan}"
                         Width="4" Height="4" Opacity="0.12"
                         Classes="particle p3" />
                <Ellipse Fill="{DynamicResource AccentMagenta}"
                         Width="2" Height="2" Opacity="0.1"
                         Classes="particle p4" />
                <Ellipse Fill="{DynamicResource AccentCyan}"
                         Width="3" Height="3" Opacity="0.15"
                         Classes="particle p5" />
            </Grid>

        </Grid>

        <!-- Dialog overlay (covers entire window) -->
        <Border Grid.ColumnSpan="2"
                IsVisible="{Binding Dialog.IsVisible}"
                Background="{DynamicResource OverlayBg}"
                Classes="dialogOverlay">
            <Border Classes="dialogCard"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding Dialog.Title}" Classes="dialogTitle" />
                    <TextBlock Text="{Binding Dialog.Message}" Classes="dialogMessage" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button Content="{Binding Dialog.CancelText}"
                                Classes="dialogGhost"
                                Command="{Binding Dialog.CancelCommand}"
                                IsVisible="{Binding Dialog.ShowCancel}" />
                        <Button Content="{Binding Dialog.ConfirmText}"
                                Classes="dialogPrimary"
                                Command="{Binding Dialog.ConfirmCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Toast notifications (top-right) -->
        <ItemsControl Grid.ColumnSpan="2"
                      ItemsSource="{Binding Toasts}"
                      Classes="toastContainer"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,16,16,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ToastNotification">
                    <Border Classes="toast"
                            IsVisible="{Binding IsVisible}"
                            BorderBrush="{Binding Type, Converter={StaticResource ToastTypeToBrushConverter}}"
                            MinHeight="44">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="{Binding Icon}" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Message}"
                                       Classes="toastMessage" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>

</Window>
