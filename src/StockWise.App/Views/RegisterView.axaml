<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StockWise.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="700"
             x:DataType="vm:RegisterViewModel"
             x:Class="StockWise.App.Views.RegisterView">

    <Grid Background="{DynamicResource BgPrimary}">

        <Ellipse Width="500" Height="500"
                 Fill="{DynamicResource AccentCyan}"
                 Opacity="0.08"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-100,-100,0,0" />
        <Ellipse Width="400" Height="400"
                 Fill="{DynamicResource AccentCyan}"
                 Opacity="0.06"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-80,-80" />

        <Border Classes="loginCard"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid RowDefinitions="Auto,*">

                <Border Grid.Row="0" Classes="loginCardTop" />

                <Border Grid.Row="1" Classes="loginCardBody">

                    <StackPanel Spacing="20" HorizontalAlignment="Stretch">

                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="📦" FontSize="48"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="StockWise"
                                       FontSize="26" FontWeight="700"
                                       Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Управление складом"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Регистрация"
                                   FontSize="18" FontWeight="600"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" />

                        <Grid Height="48" ColumnDefinitions="Auto,*">
                            <TextBlock Text="👤" Classes="loginIcon" />
                            <TextBox Grid.Column="1" Classes="loginField"
                                     Watermark="Имя пользователя"
                                     Text="{Binding Username}" />
                        </Grid>

                        <Grid Height="48" ColumnDefinitions="Auto,*">
                            <TextBlock Text="📧" Classes="loginIcon" />
                            <TextBox Grid.Column="1" Classes="loginField"
                                     Watermark="Email"
                                     Text="{Binding Email}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Grid Height="48" ColumnDefinitions="Auto,*">
                                <TextBlock Text="👤" Classes="loginIcon" />
                                <TextBox Grid.Column="1" Classes="loginField"
                                         Watermark="Имя"
                                         Text="{Binding FirstName}" />
                            </Grid>
                            <Grid Grid.Column="1" Height="48" ColumnDefinitions="Auto,*">
                                <TextBlock Text="👤" Classes="loginIcon" />
                                <TextBox Grid.Column="1" Classes="loginField"
                                         Watermark="Фамилия"
                                         Text="{Binding LastName}" />
                            </Grid>
                        </Grid>

                        <Grid Height="48" ColumnDefinitions="Auto,*">
                            <TextBlock Text="🔒" Classes="loginIcon" />
                            <TextBox Grid.Column="1" Classes="loginField"
                                     Watermark="Пароль"
                                     PasswordChar="●"
                                     Text="{Binding Password}" />
                        </Grid>

                        <Grid Height="48" ColumnDefinitions="Auto,*">
                            <TextBlock Text="🔒" Classes="loginIcon" />
                            <TextBox Grid.Column="1" Classes="loginField"
                                     Watermark="Подтверждение пароля"
                                     PasswordChar="●"
                                     Text="{Binding ConfirmPassword}" />
                        </Grid>

                        <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ"
                                Classes="loginButton"
                                Command="{Binding RegisterCommand}"
                                IsDefault="True" />

                        <StackPanel Spacing="0">
                            <Border Classes="authDivider" />
                            <Button Content="Уже есть аккаунт? Войти"
                                    Classes="authLink"
                                    Command="{Binding GoToLoginCommand}" />
                        </StackPanel>

                        <Border Classes="loginErrorBox"
                                IsVisible="{Binding HasError}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Classes="loginError" />
                        </Border>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

    </Grid>

</UserControl>
