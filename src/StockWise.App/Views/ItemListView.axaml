<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StockWise.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:DataType="vm:ItemListViewModel"
             x:Class="StockWise.App.Views.ItemListView">

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource WorkspaceBg}">

        <Border Grid.Row="0" Classes="pageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Номенклатура" Classes="pageTitle" />
                <Button Grid.Column="1" Content="+ Новый товар"
                        Classes="primaryButton"
                        Command="{Binding CreateCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="pageHeaderAccent" />

        <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="28,20,28,0">

            <Grid Grid.Row="0" ColumnDefinitions="1*,200,Auto" Margin="0,0,0,16">
                <TextBox Grid.Column="0" Classes="searchField"
                         Watermark="Поиск по названию, артикулу или штрихкоду..."
                         Text="{Binding SearchTerm}" />
                <ComboBox Grid.Column="1" Classes="filterCombo"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          PlaceholderText="Все категории"
                          Margin="12,0,0,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2" Content="⟳"
                        Classes="iconButton"
                        Command="{Binding SearchCommand}"
                        Margin="8,0,0,0"
                        ToolTip.Tip="Обновить" />
            </Grid>

            <Border Grid.Row="1" Classes="tableCard glassCard">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Margin="16,12" FontSize="13" Foreground="{DynamicResource TextTertiary}">
                        <Run Text="Загружено товаров: " />
                        <Run Text="{Binding Items.Count}" FontWeight="600" Foreground="{DynamicResource TextPrimary}" />
                    </TextBlock>

                    <StackPanel Grid.Row="1" Spacing="8" Margin="16,8"
                                IsVisible="{Binding IsLoading}">
                        <Border Classes="skeleton" Height="44" />
                        <Border Classes="skeleton" Height="44" />
                        <Border Classes="skeleton" Height="44" />
                        <Border Classes="skeleton" Height="44" />
                        <Border Classes="skeleton" Height="44" />
                        <Border Classes="skeleton" Height="44" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              Classes="dataTable"
                              ItemsSource="{Binding Items}"
                              IsVisible="{Binding HasItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Margin="4,0,4,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="120" />
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="150" />
                            <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="60" />
                            <DataGridTextColumn Header="Мин." Binding="{Binding MinStock}" Width="80" />
                            <DataGridTextColumn Header="Макс." Binding="{Binding MaxStock}" Width="80" />
                            <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="*" />
                            <DataGridTemplateColumn Header="" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <Button Content="✏️" Classes="tableActionBtn"
                                                    Command="{Binding $parent[DataGrid].DataContext.EditCommand}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip.Tip="Редактировать" />
                                            <Button Content="🗑️" Classes="tableActionBtnDanger"
                                                    Command="{Binding $parent[DataGrid].DataContext.DeleteCommand}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip.Tip="Удалить" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Classes="emptyState"
                                IsVisible="{Binding HasNoItems}">
                        <TextBlock Text="📦" Classes="emptyStateIcon" />
                        <TextBlock Text="Товары не найдены"
                                   Classes="emptyStateTitle" />
                        <TextBlock Text="Измените параметры поиска или создайте новый товар"
                                   Classes="emptyStateHint" />
                        <Button Content="+ Создать товар" Classes="primaryButton"
                                Command="{Binding CreateCommand}"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

    </Grid>

</UserControl>
