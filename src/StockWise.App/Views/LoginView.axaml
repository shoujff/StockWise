<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StockWise.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="680"
             x:DataType="vm:LoginViewModel"
             x:Class="StockWise.App.Views.LoginView">

    <Grid Background="{StaticResource SidebarBg}">

        <Ellipse Width="500" Height="500"
                 Fill="{StaticResource AccentColor}"
                 Opacity="0.08"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-100,-100,0,0" />
        <Ellipse Width="400" Height="400"
                 Fill="{StaticResource AccentColor}"
                 Opacity="0.06"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-80,-80" />

        <Border Classes="loginCard"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid RowDefinitions="Auto,*">

                <Border Grid.Row="0" Classes="loginCardTop" />

                <Border Grid.Row="1" Classes="loginCardBody">

                    <StackPanel Spacing="20" HorizontalAlignment="Stretch">

                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="📦" FontSize="48"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="StockWise"
                                       FontSize="26" FontWeight="700"
                                       Foreground="#1A1A2E"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Управление складом"
                                       FontSize="13"
                                       Foreground="#999"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Вход в систему"
                                   FontSize="18" FontWeight="600"
                                   Foreground="#333"
                                   HorizontalAlignment="Center" />

                        <Grid Height="48" ColumnDefinitions="Auto,*">
                            <TextBlock Text="👤" Classes="loginIcon" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Classes="loginField"
                                     Watermark="Имя пользователя"
                                     Text="{Binding Username}" />
                        </Grid>

                        <Grid Height="48" ColumnDefinitions="Auto,*">
                            <TextBlock Text="🔒" Classes="loginIcon" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Classes="loginField"
                                     Watermark="Пароль"
                                     PasswordChar="●"
                                     Text="{Binding Password}" />
                        </Grid>

                        <CheckBox Classes="loginCheckbox"
                                  Content="Запомнить меня" />

                        <Button Content="ВОЙТИ В СИСТЕМУ"
                                Classes="loginButton"
                                Command="{Binding LoginCommand}" />

                        <StackPanel Spacing="0">
                            <Border Classes="authDivider" />
                            <Button Content="Нет аккаунта? Зарегистрироваться"
                                    Classes="authLink"
                                    Command="{Binding GoToRegisterCommand}" />
                        </StackPanel>

                        <Border Classes="loginErrorBox"
                                IsVisible="{Binding HasError}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Classes="loginError" />
                        </Border>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

    </Grid>

</UserControl>
