<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StockWise.App.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />

        <!-- Пользовательские стили оболочки -->
        <StyleInclude Source="avares://StockWise.App/Styles/AppStyles.axaml" />
    </Application.Styles>
</Application>