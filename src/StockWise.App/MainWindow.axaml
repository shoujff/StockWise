<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StockWise.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="StockWise.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="StockWise - Управление складом"
        Width="1024" Height="768"
        WindowStartupLocation="CenterScreen">
    
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Верхняя панель (заголовок) -->
        <Border Grid.Row="0" 
                Background="{DynamicResource SystemAccentColor}"
                Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="📦 StockWise" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Version}" 
                           FontSize="12"
                           Foreground="White"
                           Opacity="0.8"
                           VerticalAlignment="Center"/>
                <Rectangle Width="1" Height="30" Fill="White" Opacity="0.3"/>
                <TextBlock Text="Управление складом" 
                           FontSize="14"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
            <Grid>
                <!-- Здесь будет контент в зависимости от навигации -->
                <TextBlock Text="Добро пожаловать в StockWise!" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="24"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>